#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
MARKETPLACE_ROOT="$(cd "$BIN_DIR/.." && pwd)"
MARKETPLACE_JSON="$MARKETPLACE_ROOT/.claude-plugin/marketplace.json"
VENDORED_PLUGIN="vendored-skills"

source "$BIN_DIR/lib/github.sh"
source "$BIN_DIR/lib/marketplace.sh"
source "$BIN_DIR/lib/deploy.sh"

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Usage: mkt <command> [options]

Commands:
  add          Add a plugin or skill from a GitHub URL
  list         List installed plugins and skills
  enable       Enable plugins (interactive picker)
  disable      Disable plugins (interactive picker)
  remove       Remove plugins or skills (interactive picker)
  update       Check vendored skills for upstream updates
  completions  Output shell completion setup instructions

Run 'mkt <command> --help' for command-specific usage.
EOF
  exit 1
}

usage_add() {
  cat <<EOF
Usage: mkt add <github-url|skills.sh-url>

Add a plugin or skills from a URL.

Behavior depends on what the URL points to:
  - A single skill (has SKILL.md) → vendors directly
  - A plugin with skills → asks: reference the whole plugin, or vendor skills
  - A plugin without skills → references the plugin
  - A skills collection → shows picker to vendor individual skills

Vendored skills are stored in the 'vendored-skills' plugin.

Examples:
  mkt add https://github.com/owner/repo/tree/main/skills/seo-audit
  mkt add https://github.com/owner/repo
  mkt add https://skills.sh/owner/repo/skill-name
EOF
  exit 1
}

usage_remove() {
  cat <<EOF
Usage: mkt remove <target>

Remove a plugin or a specific skill from the marketplace.

Target format:
  <plugin>            Remove the entire plugin (marketplace entry + local files)
  <plugin>/<skill>    Remove a single skill from a local plugin.
                      If it was the last skill, the plugin is also removed.

Examples:
  mkt remove seo-audit
  mkt remove seo-audit/seo-audit
EOF
  exit 1
}

usage_update() {
  cat <<EOF
Usage: mkt update [--dry-run] [--plugin <name>] [--skill <name>]

Check vendored skills for upstream updates and re-download newer versions.

Options:
  --dry-run          Show what would be updated without making changes.
  --plugin <name>    Only check skills in the specified plugin.
  --skill <name>     Only check a specific skill (requires --plugin).
EOF
  exit 1
}

# ── Add: skill discovery ──────────────────────────────────────────────────────

# Search a remote path for skills. Looks for:
#   1. SKILL.md directly in the path → single skill
#   2. skills/ subdirectory → list its children
#   3. Directories containing SKILL.md → list them
# Populates: FOUND_SKILL_NAMES and FOUND_SKILL_PATHS arrays.
discover_skills() {
  local search_path="$1"  # remote path to search (empty = repo root)

  FOUND_SKILL_NAMES=()
  FOUND_SKILL_PATHS=()

  # 1. Direct skill
  if [[ -n "$search_path" ]] && gh_file_exists "$GH_OWNER" "$GH_REPO" "$search_path/SKILL.md" "$GH_REF"; then
    FOUND_SKILL_NAMES+=("$(basename "$search_path")")
    FOUND_SKILL_PATHS+=("$search_path")
    return 0
  fi

  # 2. skills/ subdirectory
  local skills_dir=""
  if [[ -n "$search_path" ]]; then
    gh_file_exists "$GH_OWNER" "$GH_REPO" "$search_path/skills" "$GH_REF" && skills_dir="$search_path/skills"
  else
    gh_file_exists "$GH_OWNER" "$GH_REPO" "skills" "$GH_REF" && skills_dir="skills"
  fi

  if [[ -n "$skills_dir" ]]; then
    while IFS=$'\t' read -r type path name; do
      [[ "$type" != "dir" ]] && continue
      FOUND_SKILL_NAMES+=("$name")
      FOUND_SKILL_PATHS+=("$skills_dir/$name")
    done < <(gh_list_dir "$GH_OWNER" "$GH_REPO" "$skills_dir" "$GH_REF")
    [[ ${#FOUND_SKILL_NAMES[@]} -gt 0 ]] && return 0
  fi

  return 1
}

# Interactive multi-select picker using fzf.
# Args: header text, then items (one per arg). Already-installed items prefixed with "✓ ".
# Returns selected items (without marker) on stdout, one per line.
fzf_multi_pick() {
  local header="$1"
  shift
  local items=("$@")

  printf '%s\n' "${items[@]}" | fzf --multi \
    --header "$header" \
    --prompt "  > " \
    --bind "ctrl-a:select-all,ctrl-d:deselect-all" \
    --height 8 \
    --no-sort \
    --reverse
}

# Interactive single-select picker using fzf.
fzf_single_pick() {
  local header="$1"
  shift
  local items=("$@")

  printf '%s\n' "${items[@]}" | fzf \
    --header "$header" \
    --prompt "  > " \
    --height 5 \
    --no-sort \
    --reverse
}

# Show an interactive picker for skills and vendor the selected ones.
pick_and_vendor_skills() {
  local plugin_name="$1"

  # Build display list, marking already-installed skills
  local -a display_items=()
  for skill in "${FOUND_SKILL_NAMES[@]}"; do
    if [[ -d "$MARKETPLACE_ROOT/plugins/$plugin_name/skills/$skill" ]]; then
      display_items+=("✓ $skill")
    else
      display_items+=("  $skill")
    fi
  done

  local -a selected_raw=()
  while IFS= read -r line; do
    selected_raw+=("$line")
  done < <(fzf_multi_pick "Select skills to vendor (TAB to toggle, ENTER to confirm)" "${display_items[@]}" || true)

  [[ ${#selected_raw[@]} -eq 0 ]] && { echo "→ No skills selected."; exit 0; }

  # Strip markers from selection
  local -a selected_skills=()
  for item in "${selected_raw[@]}"; do
    selected_skills+=("$(echo "$item" | sed 's/^[✔✓ ]*//')")
  done

  echo ""
  echo "→ Vendoring ${#selected_skills[@]} skill(s) into plugin '$plugin_name'..."

  local commit_sha
  commit_sha=$(gh_resolve_sha "$GH_OWNER" "$GH_REPO" "$GH_REF")
  echo "→ Pinned to commit ${commit_sha:0:12}"

  local -a added_skills=()
  for skill_name in "${selected_skills[@]}"; do
    # Find the path for this skill name
    local skill_remote_path=""
    for ((i=0; i<${#FOUND_SKILL_NAMES[@]}; i++)); do
      if [[ "${FOUND_SKILL_NAMES[$i]}" == "$skill_name" ]]; then
        skill_remote_path="${FOUND_SKILL_PATHS[$i]}"
        break
      fi
    done

    if [[ -d "$MARKETPLACE_ROOT/plugins/$plugin_name/skills/$skill_name" ]]; then
      echo "  ⚠ '$skill_name' already exists, skipping"
      continue
    fi

    if ! gh_file_exists "$GH_OWNER" "$GH_REPO" "$skill_remote_path/SKILL.md" "$commit_sha"; then
      echo "  ⚠ No SKILL.md in $skill_name, skipping"
      continue
    fi

    vendor_skill "$GH_OWNER" "$GH_REPO" "$skill_remote_path" "$skill_name" "$plugin_name" "$commit_sha"
    added_skills+=("$skill_name")
  done

  [[ ${#added_skills[@]} -eq 0 ]] && { echo "→ No new skills added."; exit 0; }

  if ! plugin_exists "$plugin_name"; then
    add_plugin_entry "$plugin_name" "\"./plugins/$plugin_name\""
  fi

  ADDED_PLUGIN="$plugin_name"
  ADDED_SKILL="${added_skills[*]}"
}

# ── Add: helpers ──────────────────────────────────────────────────────────────

ask_reference_or_vendor() {
  local choice
  choice=$(fzf_single_pick "How do you want to add this?" \
    "Reference — full plugin (skills, agents, hooks, MCP)" \
    "Vendor    — cherry-pick individual skills to copy locally" \
    || true)

  case "$choice" in
    Reference*) echo "reference" ;;
    Vendor*)    echo "vendor" ;;
    *)          echo "cancelled" ;;
  esac
}

# Build the right source JSON for a plugin path. Repo root → url, subdir → git-subdir.
build_plugin_source() {
  local owner="$1" repo="$2" path="$3" ref="${4:-}"

  if [[ -z "$path" || "$path" == "." ]]; then
    jq -n --arg url "https://github.com/$owner/$repo.git" '{source: "url", url: $url}'
  else
    build_gitsubdir_source "$owner" "$repo" "$path" "$ref"
  fi
}

# Reference a single plugin. For repo root: url source. For subdir: git-subdir.
add_as_reference() {
  local plugin_path="$1"  # remote path (empty for repo root)

  local pjson_path="${plugin_path:+$plugin_path/}.claude-plugin/plugin.json"
  local plugin_name
  plugin_name=$(gh_file_content "$GH_OWNER" "$GH_REPO" "$pjson_path" "$GH_REF" | jq -r '.name')

  local source_json
  source_json=$(build_plugin_source "$GH_OWNER" "$GH_REPO" "$plugin_path" "$GH_REF")

  echo "→ Adding plugin '$plugin_name' as reference..."
  add_plugin_entry "$plugin_name" "$source_json"
  ADDED_PLUGIN="$plugin_name"
}

# Reference plugins from a remote marketplace.json. Shows picker if multiple.
add_marketplace_plugins_as_reference() {
  local mkt_path="${GH_SUBPATH:+$GH_SUBPATH/}.claude-plugin/marketplace.json"
  local content
  content=$(gh_file_content "$GH_OWNER" "$GH_REPO" "$mkt_path" "$GH_REF")

  local plugin_root
  plugin_root=$(echo "$content" | jq -r '.metadata.pluginRoot // "."')
  plugin_root="${plugin_root#./}"

  # Collect local plugins from the remote marketplace
  local -a plugin_names=()
  local -a plugin_paths=()
  while IFS= read -r pname; do
    [[ -z "$pname" ]] && continue
    local psource
    psource=$(echo "$content" | jq -r --arg n "$pname" '.plugins[] | select(.name == $n) | .source')
    # Only handle local sources (string starting with ./)
    [[ "$psource" != ./* ]] && continue
    local ppath="${psource#./}"
    [[ -n "$plugin_root" && "$plugin_root" != "." ]] && ppath="$plugin_root/$ppath"
    [[ -n "$GH_SUBPATH" ]] && ppath="$GH_SUBPATH/$ppath"
    plugin_names+=("$pname")
    plugin_paths+=("$ppath")
  done <<< "$(echo "$content" | jq -r '.plugins[].name')"

  if [[ ${#plugin_names[@]} -eq 0 ]]; then
    echo "  No local plugins found in marketplace"
    exit 1
  fi

  if [[ ${#plugin_names[@]} -eq 1 ]]; then
    # Single plugin — add directly
    local pname="${plugin_names[0]}"
    local ppath="${plugin_paths[0]}"
    echo "→ Found plugin '$pname'"
    local source_json
    source_json=$(build_plugin_source "$GH_OWNER" "$GH_REPO" "$ppath" "$GH_REF")
    add_plugin_entry "$pname" "$source_json"
    ADDED_PLUGIN="$pname"
    return
  fi

  # Multiple — fzf picker
  local -a display_items=()
  for pname in "${plugin_names[@]}"; do
    if plugin_exists "$pname"; then
      display_items+=("✓ $pname")
    else
      display_items+=("  $pname")
    fi
  done

  local -a selected_raw=()
  while IFS= read -r line; do
    selected_raw+=("$line")
  done < <(fzf_multi_pick "Select plugins to reference (TAB to toggle, ENTER to confirm)" "${display_items[@]}" || true)

  [[ ${#selected_raw[@]} -eq 0 ]] && { echo "→ No plugins selected."; exit 0; }

  for item in "${selected_raw[@]}"; do
    local pname
    pname=$(echo "$item" | sed 's/^[✓ ]* //')

    # Find path for this plugin name
    local ppath=""
    for ((i=0; i<${#plugin_names[@]}; i++)); do
      if [[ "${plugin_names[$i]}" == "$pname" ]]; then
        ppath="${plugin_paths[$i]}"
        break
      fi
    done

    local source_json
    source_json=$(build_plugin_source "$GH_OWNER" "$GH_REPO" "$ppath" "$GH_REF")
    add_plugin_entry "$pname" "$source_json"
  done

  # Use first selected as ADDED_PLUGIN for deploy summary
  ADDED_PLUGIN="${plugin_names[${selected_indices[0]}]}"
}

# Vendor a single skill directly (no picker).
vendor_single_skill() {
  local skill_path="$1"
  local skill_name="$2"
  local plugin_name="$3"

  if [[ -d "$MARKETPLACE_ROOT/plugins/$plugin_name/skills/$skill_name" ]]; then
    echo "→ Skill '$skill_name' already exists in plugin '$plugin_name', nothing to do."
    exit 0
  fi

  echo "→ Vendoring skill '$skill_name' into plugin '$plugin_name'..."

  local commit_sha
  commit_sha=$(gh_resolve_sha "$GH_OWNER" "$GH_REPO" "$GH_REF")
  echo "→ Pinned to commit ${commit_sha:0:12}"

  vendor_skill "$GH_OWNER" "$GH_REPO" "$skill_path" "$skill_name" "$plugin_name" "$commit_sha"

  if ! plugin_exists "$plugin_name"; then
    add_plugin_entry "$plugin_name" "\"./plugins/$plugin_name\""
  fi

  ADDED_PLUGIN="$plugin_name"
  ADDED_SKILL="$skill_name"
}

# Vendor discovered skills — single goes direct, multiple shows picker.
vendor_discovered_skills() {
  local plugin_name="$1"

  echo "→ Found ${#FOUND_SKILL_NAMES[@]} skill(s)"

  if [[ ${#FOUND_SKILL_NAMES[@]} -eq 1 ]]; then
    vendor_single_skill "${FOUND_SKILL_PATHS[0]}" "${FOUND_SKILL_NAMES[0]}" "$plugin_name"
  else
    pick_and_vendor_skills "$plugin_name"
  fi
}

# ── Command: add ──────────────────────────────────────────────────────────────

cmd_add() {
  local url=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h) usage_add ;;
      -*)        echo "Error: Unknown option $1"; usage_add ;;
      *)         url="$1"; shift ;;
    esac
  done

  [[ -z "$url" ]] && usage_add

  parse_github_url "$url"
  echo "→ Parsed: owner=$GH_OWNER repo=$GH_REPO ref=${GH_REF:-default} path=${GH_SUBPATH:-root}"

  ADDED_PLUGIN=""
  ADDED_SKILL=""

  # Direct skill URL — vendor it, no questions
  if [[ -n "$GH_SUBPATH" ]] && gh_file_exists "$GH_OWNER" "$GH_REPO" "$GH_SUBPATH/SKILL.md" "$GH_REF"; then
    vendor_single_skill "$GH_SUBPATH" "$(basename "$GH_SUBPATH")" "$VENDORED_PLUGIN"

  # Has marketplace.json — ask reference or vendor
  elif gh_file_exists "$GH_OWNER" "$GH_REPO" "${GH_SUBPATH:+$GH_SUBPATH/}.claude-plugin/marketplace.json" "$GH_REF"; then
    local mode
    mode=$(ask_reference_or_vendor)
    [[ "$mode" == "cancelled" ]] && exit 0

    if [[ "$mode" == "reference" ]]; then
      add_marketplace_plugins_as_reference
    else
      discover_skills "$GH_SUBPATH" || { echo "Error: No skills found"; exit 1; }
      vendor_discovered_skills "$VENDORED_PLUGIN"
    fi

  # Has plugin.json — ask reference or vendor
  elif gh_file_exists "$GH_OWNER" "$GH_REPO" "${GH_SUBPATH:+$GH_SUBPATH/}.claude-plugin/plugin.json" "$GH_REF"; then
    local mode
    mode=$(ask_reference_or_vendor)
    [[ "$mode" == "cancelled" ]] && exit 0

    if [[ "$mode" == "reference" ]]; then
      add_as_reference "$GH_SUBPATH"
    else
      discover_skills "$GH_SUBPATH" || { echo "Error: No skills found"; exit 1; }
      vendor_discovered_skills "$VENDORED_PLUGIN"
    fi

  # No manifest — look for skills directly
  else
    discover_skills "$GH_SUBPATH" || { echo "Error: No skills or plugin found at this URL"; exit 1; }
    vendor_discovered_skills "$VENDORED_PLUGIN"
  fi

  # Deploy
  local -a stage_paths=(".claude-plugin/marketplace.json")
  local -a deploy_changes=()

  if [[ -n "$ADDED_PLUGIN" ]]; then
    if [[ -n "$ADDED_SKILL" ]]; then
      stage_paths+=("plugins/")
      for skill in $ADDED_SKILL; do
        deploy_changes+=("+$ADDED_PLUGIN/$skill")
      done
    else
      deploy_changes+=("+$ADDED_PLUGIN")
    fi
  fi

  [[ ${#deploy_changes[@]} -eq 0 ]] && { echo "→ Nothing to deploy."; exit 0; }

  deploy "feat: add from $GH_OWNER/$GH_REPO" "${stage_paths[@]}" "--" "${deploy_changes[@]}"
}

# ── Command: update ───────────────────────────────────────────────────────────

cmd_update() {
  local dry_run=0
  local filter_plugin=""
  local filter_skill=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)  dry_run=1; shift ;;
      --plugin)   filter_plugin="$2"; shift 2 ;;
      --skill)    filter_skill="$2"; shift 2 ;;
      --help|-h)  usage_update ;;
      *)          echo "Error: Unknown argument $1"; usage_update ;;
    esac
  done

  if [[ -n "$filter_skill" && -z "$filter_plugin" ]]; then
    echo "Error: --skill requires --plugin"
    exit 1
  fi

  echo "→ Scanning for vendored skills..."
  echo ""

  local updated=0 checked=0
  local -a update_changes=()

  while IFS= read -r upstream_file; do
    [[ -z "$upstream_file" ]] && continue

    local rel_path="${upstream_file#$MARKETPLACE_ROOT/plugins/}"
    local plugin_name="${rel_path%%/*}"
    local skill_name
    skill_name="$(basename "$(dirname "$upstream_file")")"

    [[ -n "$filter_plugin" && "$plugin_name" != "$filter_plugin" ]] && continue
    [[ -n "$filter_skill" && "$skill_name" != "$filter_skill" ]] && continue

    checked=$((checked + 1))

    if check_and_update_skill "$upstream_file" "$plugin_name" "$skill_name" "$dry_run"; then
      updated=$((updated + 1))
      update_changes+=("~$plugin_name/$skill_name")
    fi

  done < <(find "$MARKETPLACE_ROOT/plugins" -name '.upstream.json' -type f 2>/dev/null)

  echo ""

  if [[ $checked -eq 0 ]]; then
    echo "→ No vendored skills found."
    exit 0
  fi

  echo "→ Checked $checked skill(s), $updated update(s)"

  if [[ $dry_run -eq 1 ]]; then
    echo "→ Dry run — no changes made."
    exit 0
  fi

  if [[ $updated -eq 0 ]]; then
    echo "→ Everything is up to date."
    exit 0
  fi

  deploy "feat: update $updated vendored skill(s)" "plugins/" "--" "${update_changes[@]}"
}

# Check a single vendored skill for updates. Returns 0 if updated, 1 if skipped.
check_and_update_skill() {
  local upstream_file="$1"
  local plugin_name="$2"
  local skill_name="$3"
  local dry_run="$4"

  local repo_url remote_path pinned_commit
  repo_url=$(jq -r '.repository' "$upstream_file")
  remote_path=$(jq -r '.path' "$upstream_file")
  pinned_commit=$(jq -r '.commit' "$upstream_file")

  local owner_repo
  owner_repo=$(gh_parse_repo_url "$repo_url")
  if [[ -z "$owner_repo" ]]; then
    echo "  ⚠ Cannot parse repository URL: $repo_url (skipping $plugin_name/$skill_name)"
    return 1
  fi

  local owner="${owner_repo%%/*}"
  local repo="${owner_repo##*/}"

  echo "  [$plugin_name/$skill_name] $owner/$repo:$remote_path"
  echo "    pinned: ${pinned_commit:0:12}"

  local latest_commit
  latest_commit=$(gh_latest_commit_for_path "$owner" "$repo" "$remote_path")

  if [[ -z "$latest_commit" ]]; then
    echo "    ⚠ Could not resolve latest commit (skipping)"
    return 1
  fi

  echo "    latest: ${latest_commit:0:12}"

  if [[ "$pinned_commit" == "$latest_commit" ]]; then
    echo "    ✓ up to date"
    return 1
  fi

  echo "    ↑ update available"

  if [[ $dry_run -eq 1 ]]; then
    return 0
  fi

  update_skill "$(dirname "$upstream_file")" "$owner" "$repo" "$remote_path" "$latest_commit" "$repo_url"
  return 0
}

# ── Command: list ──────────────────────────────────────────────────────────────

# Get locally enabled plugin names.
get_enabled_plugins() {
  claude plugin list 2>/dev/null | grep -o '[^ ]*@nexaedge-marketplace' | sed 's/@nexaedge-marketplace//'
}

is_enabled() {
  local name="$1"
  echo "$ENABLED_PLUGINS" | grep -qx "$name"
}

# Collect all plugins and skills into display lines.
# Prefixes enabled plugins with ✔. Format:
#   "✔ plugin/skill" or "  plugin/skill" for vendored
#   "✔ plugin (external)" or "  plugin (external)" for references
collect_installed_items() {
  ENABLED_PLUGINS=$(get_enabled_plugins)
  local -a items=()

  # Vendored plugins (only those with at least one .upstream.json)
  for plugin_dir in "$MARKETPLACE_ROOT"/plugins/*/; do
    [[ -d "$plugin_dir" ]] || continue
    local pname
    pname=$(basename "$plugin_dir")

    # Skip authored plugins (no .upstream.json anywhere)
    find "$plugin_dir" -name '.upstream.json' -print -quit 2>/dev/null | grep -q . || continue

    local marker="  "
    is_enabled "$pname" && marker="✔ "

    local skills_dir="$plugin_dir/skills"
    if [[ -d "$skills_dir" ]]; then
      for skill_dir in "$skills_dir"/*/; do
        [[ -d "$skill_dir" ]] || continue
        local sname
        sname=$(basename "$skill_dir")
        items+=("${marker}$pname/$sname (vendored)")
      done
    fi
  done

  # External plugins from marketplace.json (non-local sources)
  while IFS= read -r pname; do
    [[ -z "$pname" ]] && continue
    local psource
    psource=$(jq -r --arg n "$pname" '.plugins[] | select(.name == $n) | .source | if type == "object" then .source else "local" end' "$MARKETPLACE_JSON")
    if [[ "$psource" != "local" ]]; then
      local marker="  "
      is_enabled "$pname" && marker="✔ "
      items+=("${marker}$pname (external)")
    fi
  done <<< "$(jq -r '.plugins[].name' "$MARKETPLACE_JSON")"

  printf '%s\n' "${items[@]}"
}

cmd_list() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<EOF
Usage: mkt list

List all installed plugins and vendored skills.
EOF
    exit 0
  fi

  echo "→ Installed plugins and skills:"
  echo ""

  local current_plugin=""

  while IFS= read -r item; do
    [[ -z "$item" ]] && continue

    # Strip marker for parsing, keep for display
    local marker="${item:0:2}"
    local content="${item:2}"

    if [[ "$content" == *" (external)" ]]; then
      echo "  ${item}"
    elif [[ "$content" == */* ]]; then
      local stripped="${content% (vendored)}"
      local pname="${stripped%%/*}"
      local sname="${stripped#*/}"

      if [[ "$pname" != "$current_plugin" ]]; then
        [[ -n "$current_plugin" ]] && echo ""
        local version
        version=$(jq -r '.version // "?"' "$MARKETPLACE_ROOT/plugins/$pname/.claude-plugin/plugin.json" 2>/dev/null || echo "?")
        echo "  ${marker}$pname $version (vendored)"
        current_plugin="$pname"
      fi

      echo "      $sname"
    fi
  done <<< "$(collect_installed_items | sort)"
  echo ""
}

# ── Command: enable ────────────────────────────────────────────────────────────

cmd_enable() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: mkt enable [plugin]"
    echo ""
    echo "Enable a plugin. Shows an interactive picker if no argument given."
    exit 0
  fi

  # Get all marketplace plugins and their install/enabled status
  local installed_json
  installed_json=$(claude plugin list --json 2>/dev/null | tr -d '\033' | sed 's/\[>[0-9;]*m//g' || echo "[]")

  local -a all_plugins=()
  while IFS= read -r pname; do
    [[ -z "$pname" ]] && continue
    all_plugins+=("$pname")
  done <<< "$(jq -r '.plugins[].name' "$MARKETPLACE_JSON")"

  # Build display items — show disabled plugins (not installed or installed but disabled)
  local -a items=()
  for pname in "${all_plugins[@]}"; do
    local is_enabled
    is_enabled=$(echo "$installed_json" | jq -r --arg id "${pname}@nexaedge-marketplace" \
      '.[] | select(.id == $id) | .enabled // false' 2>/dev/null || echo "false")

    [[ "$is_enabled" == "true" ]] && continue
    items+=("$pname")
  done

  local -a targets=()

  if [[ $# -ge 1 ]]; then
    targets+=("$1")
  else
    if [[ ${#items[@]} -eq 0 ]]; then
      echo "→ All plugins are already enabled."
      exit 0
    fi

    while IFS= read -r line; do
      [[ -n "$line" ]] && targets+=("$line")
    done < <(fzf_multi_pick "Select plugins to enable (TAB to toggle, ENTER to confirm)" "${items[@]}" || true)

    [[ ${#targets[@]} -eq 0 ]] && exit 0
  fi

  for pname in "${targets[@]}"; do
    local is_installed=0
    echo "$installed_json" | jq -e --arg id "${pname}@nexaedge-marketplace" '.[] | select(.id == $id)' &>/dev/null && is_installed=1

    if [[ $is_installed -eq 0 ]]; then
      echo "→ Installing and enabling '$pname'..."
      claude plugin install "${pname}@nexaedge-marketplace" --scope user 2>/dev/null || true
    else
      echo "→ Enabling '$pname'..."
      claude plugin enable "${pname}@nexaedge-marketplace" --scope user 2>/dev/null || true
    fi
  done

  echo ""
  echo "  Restart Claude Code to apply changes."
}

# ── Command: disable ──────────────────────────────────────────────────────────

cmd_disable() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: mkt disable [plugin]"
    echo ""
    echo "Disable an enabled plugin. Shows an interactive picker if no argument given."
    exit 0
  fi

  local installed_json
  installed_json=$(claude plugin list --json 2>/dev/null | tr -d '\033' | sed 's/\[>[0-9;]*m//g' || echo "[]")

  # Only show enabled plugins
  local -a enabled_plugins=()
  while IFS= read -r pname; do
    [[ -z "$pname" ]] && continue
    enabled_plugins+=("$pname")
  done <<< "$(echo "$installed_json" | jq -r '.[] | select(.enabled == true) | .id' | sed 's/@nexaedge-marketplace//')"

  if [[ ${#enabled_plugins[@]} -eq 0 ]]; then
    echo "→ No enabled plugins."
    exit 0
  fi

  local -a targets=()

  if [[ $# -ge 1 ]]; then
    targets+=("$1")
  else
    local -a items=()
    for pname in "${enabled_plugins[@]}"; do
      items+=("$pname")
    done

    while IFS= read -r line; do
      [[ -n "$line" ]] && targets+=("$line")
    done < <(fzf_multi_pick "Select plugins to disable (TAB to toggle, ENTER to confirm)" "${items[@]}" || true)

    [[ ${#targets[@]} -eq 0 ]] && exit 0
  fi

  for pname in "${targets[@]}"; do
    echo "→ Disabling '$pname'..."
    claude plugin disable "${pname}@nexaedge-marketplace" --scope user 2>/dev/null || true
  done

  echo ""
  echo "  Restart Claude Code to apply changes."
}

# ── Command: remove ────────────────────────────────────────────────────────────

cmd_remove() {
  [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage_remove

  local -a targets=()

  if [[ $# -ge 1 ]]; then
    # Direct argument
    targets+=("$1")
  else
    # Interactive picker
    local -a items=()
    while IFS= read -r line; do
      [[ -n "$line" ]] && items+=("$line")
    done <<< "$(collect_installed_items)"

    if [[ ${#items[@]} -eq 0 ]]; then
      echo "→ Nothing installed."
      exit 0
    fi

    while IFS= read -r line; do
      # Strip marker, labels, and whitespace
      line="${line% (external)}"
      line="${line% (vendored)}"
      line=$(echo "$line" | sed 's/^[✔ ]*//')
      [[ -n "$line" ]] && targets+=("$line")
    done < <(fzf_multi_pick "Select items to remove (TAB to toggle, ENTER to confirm)" "${items[@]}" || true)

    [[ ${#targets[@]} -eq 0 ]] && exit 0
  fi

  # Process all removals, collecting stage paths and change entries
  local -a stage_paths=()
  local -a deploy_changes=()
  local has_plugin_changes=0
  local has_local_changes=0

  for target in "${targets[@]}"; do
    local plugin_name=""
    local skill_name=""

    if [[ "$target" == */* ]]; then
      plugin_name="${target%%/*}"
      skill_name="${target#*/}"
    else
      plugin_name="$target"
    fi

    REMOVED_PLUGIN=""

    if [[ -n "$skill_name" ]]; then
      echo "→ Removing skill '$skill_name' from plugin '$plugin_name'..."
      remove_local_skill "$plugin_name" "$skill_name"
      has_local_changes=1
      [[ -n "$REMOVED_PLUGIN" ]] && has_plugin_changes=1
      deploy_changes+=("-$plugin_name/$skill_name")
    else
      echo "→ Removing plugin '$plugin_name'..."

      if is_local_plugin "$plugin_name"; then
        remove_local_plugin "$plugin_name"
        has_local_changes=1
      fi

      if plugin_exists "$plugin_name"; then
        remove_plugin_entry "$plugin_name"
        has_plugin_changes=1
      fi

      deploy_changes+=("-$plugin_name")
    fi
  done

  [[ ${#deploy_changes[@]} -eq 0 ]] && { echo "→ Nothing to remove."; exit 0; }

  [[ $has_local_changes -eq 1 ]] && stage_paths+=("plugins/")
  [[ $has_plugin_changes -eq 1 ]] && stage_paths+=(".claude-plugin/marketplace.json")

  local names
  names=$(printf '%s\n' "${targets[@]}" | head -3 | tr '\n' ', ' | sed 's/,$//')
  [[ ${#targets[@]} -gt 3 ]] && names="$names, ..."

  deploy "feat: remove $names" "${stage_paths[@]}" "--" "${deploy_changes[@]}"
}

# ── Command: completions ──────────────────────────────────────────────────────

cmd_completions() {
  local shell="${1:-}"
  local completions_dir="$BIN_DIR/completions"

  if [[ "$shell" == "--help" || "$shell" == "-h" ]]; then
    cat <<EOF
Usage: mkt completions [bash|zsh]

Print shell completion setup instructions.
Without arguments, auto-detects the current shell.
EOF
    exit 0
  fi

  if [[ -z "$shell" ]]; then
    case "${SHELL##*/}" in
      zsh)  shell="zsh" ;;
      bash) shell="bash" ;;
      *)    echo "Error: Cannot detect shell. Specify 'bash' or 'zsh'."; exit 1 ;;
    esac
  fi

  case "$shell" in
    zsh)
      cat <<EOF
# Add to your .zshrc:
fpath=($completions_dir \$fpath)
autoload -Uz compinit && compinit
EOF
      ;;
    bash)
      cat <<EOF
# Add to your .bashrc:
source $completions_dir/mkt.bash
EOF
      ;;
    *)
      echo "Error: Unsupported shell '$shell'. Use 'bash' or 'zsh'."
      exit 1
      ;;
  esac
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

[[ $# -lt 1 ]] && usage

command="$1"
shift

case "$command" in
  add)         cmd_add "$@" ;;
  list|ls)     cmd_list "$@" ;;
  enable)      cmd_enable "$@" ;;
  disable)     cmd_disable "$@" ;;
  remove|rm)   cmd_remove "$@" ;;
  update)      cmd_update "$@" ;;
  completions) cmd_completions "$@" ;;
  --help|-h)   usage ;;
  *)           echo "Error: Unknown command '$command'"; usage ;;
esac
